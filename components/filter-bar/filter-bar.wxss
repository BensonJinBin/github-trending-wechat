.filter-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background-color: var(--bg);
  border-bottom: 1rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}

/* 时间段按钮组 */
.period-group {
  display: flex;
  gap: 0;
  background-color: var(--bg3);
  border-radius: 12rpx;
  padding: 4rpx;
}

.period-btn {
  padding: 10rpx 28rpx;
  border-radius: 10rpx;
  color: var(--text2);
  font-size: 26rpx;
  transition: background-color 0.15s, color 0.15s;
}

.period-btn--active {
  background-color: var(--bg);
  color: var(--text);
  font-weight: 600;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.12);
}

.period-btn--hover {
  opacity: 0.7;
}

/* 语言 picker */
.lang-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 24rpx;
  background-color: var(--bg3);
  border-radius: 12rpx;
  max-width: 220rpx;
}

.lang-picker-text {
  color: var(--text);
  font-size: 26rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.lang-picker-chevron {
  color: var(--text3);
  font-size: 24rpx;
  flex-shrink: 0;
}
